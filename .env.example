# .env.example — Copia como .env y rellena con tus valores reales
# NO subas .env al repositorio (ya esta en .gitignore)

ODDS_API_KEY=TU_ODDS_API_KEY_AQUI
TELEGRAM_TOKEN=TU_TELEGRAM_BOT_TOKEN_AQUI
API_FOOTBALL_KEY=
BALLDONTLIE_API_KEY=

ADMIN_CHAT_ID=TU_TELEGRAM_ID_AQUI
SUPPORT_CHAT_ID=TU_TELEGRAM_ID_AQUI
SUPPORT_USERNAME=TU_USERNAME_SOPORTE

CHANNEL_ID_BANKERS=-100XXXXXXXXXX
CHANNEL_ID_FREE=-100XXXXXXXXXX

GOOGLE_SHEET_NAME=DB_BET

# ── TikTok (Content Posting API v2) ──────────────
# Setup: python -m modules.tiktok_uploader --auth
TIKTOK_CLIENT_KEY=
